<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <Authors>st0o0</Authors>
        <Title>NaschStorage.Azure.Blobs</Title>
        <PackageTags>Storage;BlobStorage;Azure;AzureBlob;Akka;Akka.Streams;Streaming</PackageTags>
        <PackageReadmeFile>README.md</PackageReadmeFile>
        <PackageLicenseExpression>MIT</PackageLicenseExpression>
        <PackageProjectUrl>https://github.com/st0o0/NaschStorage</PackageProjectUrl>
        <RepositoryUrl>https://github.com/st0o0/NaschStorage.git</RepositoryUrl>
        <RepositoryType>git</RepositoryType>
        <Copyright>Copyright (c) 2026-$([System.DateTime]::Now.Year) st0o0</Copyright>
    </PropertyGroup>
    <PropertyGroup>
        <IsPackable>true</IsPackable>
        <RestorePackagesWithLockFile>true</RestorePackagesWithLockFile>
    </PropertyGroup>
    <PropertyGroup>
        <PublishRepositoryUrl>true</PublishRepositoryUrl>
        <DebugType>embedded</DebugType>
        <EmbedUntrackedSources>true</EmbedUntrackedSources>
    </PropertyGroup>
    <ItemGroup>
        <PackageReference Include="Azure.Storage.Blobs" />
    </ItemGroup>
    <ItemGroup>
        <ProjectReference Include="..\NaschStorage\NaschStorage.csproj" />
    </ItemGroup>
    <ItemGroup>
        <None Include="../../README.md" Pack="true" Visible="false" PackagePath="\" />
        <None Include="../../LICENSE" Pack="true" Visible="false" PackagePath="\" />
        <None Remove="packages.lock.json" />
    </ItemGroup>
</Project>
